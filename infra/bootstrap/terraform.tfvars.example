state_bucket_name  = "replace-with-globally-unique-bucket"
lock_instance_name = "portfolio-lock"
github_oidc_fingerprints = [
  "REPLACE_WITH_40_CHARACTER_SHA1_FINGERPRINT",
]

github_oidc_subjects = [
  "REPLACE_WITH_EXACT_INFRA_PLAN_ENVIRONMENT_SUBJECT",
  "REPLACE_WITH_EXACT_INFRA_APPLY_ENVIRONMENT_SUBJECT",
]

